{
  "name": "ai-desktop-copilot",
  "version": "1.0.0",
  "description": "AI Desktop Copilot - Natural Language to SQL Query Engine",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "npx electron . --enable-logging",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "author": "AI Desktop Copilot",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-log": "^5.0.0"
  },
  "build": {
    "appId": "com.aicopilot.desktop",
    "productName": "AI Desktop Copilot",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}

